FROM python:3.12-slim

WORKDIR /app

COPY caregiver-dashboard/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt gunicorn

COPY caregiver-dashboard/ .

ENV RAILWAY_ENVIRONMENT=production

EXPOSE 5555

CMD gunicorn --bind 0.0.0.0:${PORT:-5555} --workers 2 --threads 4 --timeout 120 app:app
